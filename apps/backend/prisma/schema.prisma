generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
}

model User {
  id          String           @id @default(cuid())
  email       String           @unique
  username    String           @unique
  createdAt   DateTime         @default(now())
  votes       Vote[]
  comments    Comment[]
  preferences UserPreference?
  bookmarks   Bookmark[]
  referrals   Referral[]
  submissions UserSubmission[]
  reputation  Int              @default(0)
}

model UserPreference {
  id              String     @id @default(cuid())
  userId          String     @unique
  categories      Category[]
  excludedSources String[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Article {
  id              String          @id @default(cuid())
  title           String
  summary         String
  imageUrl        String?
  sourceUrl       String          @unique
  sourceName      String
  category        Category
  publishedAt     DateTime
  createdAt       DateTime        @default(now())
  isAd            Boolean         @default(false)
  sourceCount     Int             @default(1)
  importanceScore Int             @default(5)
  feedScore       Float           @default(0)
  isBreaking      Boolean         @default(false)
  breakingScore   Float           @default(0)
  submittedBy     String?
  votes           Vote[]
  comments        Comment[]
  bookmarks       Bookmark[]
  sources         GistSource[]
  submission      UserSubmission?
}

model GistSource {
  id         String  @id @default(cuid())
  articleId  String
  sourceName String
  sourceUrl  String
  imageUrl   String?
  article    Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  value     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  body      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
}

model PredictionMarket {
  id           String    @id @default(cuid())
  externalId   String    @unique
  platform     String
  question     String
  category     Category
  yesPrice     Float
  volume       Float     @default(0)
  url          String
  affiliateUrl String?
  imageUrl     String?
  endDate      DateTime?
  lastUpdated  DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([category])
}

model Referral {
  id             String    @id @default(cuid())
  referrerId     String
  referralCode   String    @unique
  referredEmail  String?
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  referrer       User      @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

model UserSubmission {
  id          String   @id @default(cuid())
  userId      String
  title       String
  url         String
  category    Category
  description String?
  status      String   @default("pending")
  articleId   String?  @unique
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article     Article? @relation(fields: [articleId], references: [id])

  @@index([userId])
  @@index([status])
}

enum Category {
  TECH
  FINANCE
  POLITICS
  CULTURE
  SPORTS
}
